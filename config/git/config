[user]
    name = Miro Ali Akbar
    email = 113117782+Miro-Ali-Akbar@users.noreply.github.com

[core]
    compression = 9
    whitespace = error
    preloadindex = true

[alias]
    undo = reset --soft HEAD^

[status]
    branch = true
    showStash = true

[diff]
    context = 3
    renames = copies
    interHunkContext = 10
    conflictstyle = diff3

[push]
    autosetupremote = true
    default = current
    recursesubmodules = on-demand
    followtags = true

[pull]
    default = current
    rebase = true

[fetch]
    prune = true

[log]
    abbrevCommit = true

[advice]
    statusHints = false

[init]
    defaultbranch = main

[submodule]
    recurse = true

[url "https://github.com/Miro-Ali-Akbar/"]

    insteadOf = "miro:"

[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
